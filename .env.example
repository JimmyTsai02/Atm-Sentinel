# 請複製成 .env，並填入你的 OpenAI API key。
OPENAI_API_KEY=sk-your-openai-api-key

# MVP 預設使用 gpt-4o。
OPENAI_MODEL=gpt-4o
OPENAI_MAX_RETRIES=3

# 影像來源設定：若 RTSP_URL 有值，會優先使用 RTSP；否則使用 CAMERA_INDEX。
CAMERA_INDEX=0
RTSP_URL=
SAMPLE_FPS=1
FRAME_WIDTH=640
FRAME_HEIGHT=480

# YOLO 設定。
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
LINGER_THRESHOLD_SEC=30
EVENT_COOLDOWN_SEC=20
OCCLUSION_DARK_RATIO=0.75
OCCLUSION_BRIGHT_RATIO=0.85
OCCLUSION_EDGE_DENSITY=0.015
OCCLUSION_BLUR_VARIANCE=35
OCCLUSION_STDDEV=28
OCCLUSION_CONSECUTIVE_FRAMES=2

# 本地記錄。
LOG_DIR=logs
DB_PATH=atm_guard.db
